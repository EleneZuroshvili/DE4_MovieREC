{
	"name": "CEU AI Engineering Class",
	"image": "ghcr.io/zoltanctoth/ai-engineering-class:latest-release",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/ceu-ai-engineering-class,type=bind",
	"forwardPorts": [5000],
	"postCreateCommand": "uv sync",
	"customizations": {
		"vscode": {
			"extensions": ["ms-python.python", "ms-toolsai.jupyter", "ms-vscode.live-server", "anthropic.claude-vscode"],
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.terminal.activateEnvironment": true
			}
		}
	}
}
